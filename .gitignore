### https://raw.github.com/github/gitignore/master/Rust.gitignore

# Generated by Cargo
debug/
target/

# rustfmt backups
**/*.rs.bk

# JetBrains IDE
/.idea/

# Generated test PKI / secrets — never commit
*.pem
*.key
*.crt

*.qcow2

# Nix build result symlinks (point at machine-local /nix/store paths)
/result
/result-*
